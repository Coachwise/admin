# NO QUOTES around any value.
#
# dotenv (used here in dev) strips surrounding quotes, but `docker run
# --env-file` does NOT — it takes the line literally. A quoted DATABASE_URL
# therefore works locally and then reaches the container with a leading `"`
# still attached, which is not a valid URL, and the app dies with the wonderfully
# unhelpful `getaddrinfo EAI_AGAIN base`. Keep both files in the same style so
# nobody copies quotes onto the server. See src/env.js.

# The Coachwise database. The admin panel talks to it directly.
DATABASE_URL=postgres://coachwise:passwd@localhost:5432/coachwise

# Signs the admin session cookie. Any long random string (openssl rand -hex 32).
# Must be stable across restarts, or everyone gets logged out.
ADMIN_COOKIE_SECRET=change-me-to-a-long-random-string

PORT=8100
