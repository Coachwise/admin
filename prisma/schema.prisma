}

model exercise_categories {
  id         String               @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  slug       String               @unique @db.VarChar(96)
  name_i18n  Json                 @default("{}")
  sport_type exercise_sport_type?
  sort_order Int                  @default(0)
  created_at DateTime?            @default(now()) @db.Timestamp(6)
  updated_at DateTime?            @default(now()) @db.Timestamp(6)
  exercises  exercises[]

  @@index([sport_type], map: "idx_exercise_categories_sport_type")
}

model exercises {
  id                  String                   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  user_id             String?                  @db.Uuid
  name                String                   @db.VarChar(128)
  description         String
  public              Boolean?                 @default(false)
  created_at          DateTime?                @default(now()) @db.Timestamp(6)
  updated_at          DateTime?                @default(now()) @db.Timestamp(6)
  media_id            String?                  @db.Uuid
  sport_type          exercise_sport_type      @default(GENERAL)
  slug                String?                  @unique @db.VarChar(96)
  name_i18n           Json                     @default("{}")
  description_i18n    Json                     @default("{}")
  category_id         String?                  @db.Uuid
  search_vector       Unsupported("tsvector")? @default(dbgenerated("to_tsvector('simple'::regconfig, (((((((((((((COALESCE(name, ''::character varying))::text || ' '::text) || COALESCE(description, ''::text)) || ' '::text) || COALESCE((name_i18n ->> 'en'::text), ''::text)) || ' '::text) || COALESCE((name_i18n ->> 'fa'::text), ''::text)) || ' '::text) || COALESCE((description_i18n ->> 'en'::text), ''::text)) || ' '::text) || COALESCE((description_i18n ->> 'fa'::text), ''::text)) || ' '::text) || COALESCE(replace((slug)::text, '-'::text, ' '::text), ''::text)))"))
  exercise_categories exercise_categories?     @relation(fields: [category_id], references: [id], onUpdate: NoAction)
  media               media?                   @relation(fields: [media_id], references: [id], onUpdate: NoAction)
  users               users?                   @relation(fields: [user_id], references: [id], onUpdate: NoAction, map: "fk_user")
  plan_exercises      plan_exercises[]
  sets                sets[]
  test_items          test_items[]
  workout_logs        workout_logs[]

  @@index([category_id], map: "idx_exercises_category_id")
  @@index([media_id], map: "idx_exercises_media_id")
  @@index([search_vector], map: "idx_exercises_search_vector", type: Gin)
  @@index([sport_type], map: "idx_exercises_sport_type")
}

