generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model achievements {
  id                                   String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  athlete_id                           String   @db.Uuid
  coach_id                             String   @db.Uuid
  title                                String   @db.VarChar(128)
  description                          String?
  created_at                           DateTime @default(now()) @db.Timestamp(6)
  users_achievements_athlete_idTousers users    @relation("achievements_athlete_idTousers", fields: [athlete_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "achievements_athlete_fk")
  users_achievements_coach_idTousers   users    @relation("achievements_coach_idTousers", fields: [coach_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "achievements_coach_fk")

  @@index([athlete_id, created_at(sort: Desc)], map: "idx_achievements_athlete")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model chat_members {
  chat_id    String   @db.Uuid
  user_id    String   @db.Uuid
  role       String   @db.VarChar(16)
  created_at DateTime @default(now()) @db.Timestamp(6)
  chats      chats    @relation(fields: [chat_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  users      users    @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@id([chat_id, user_id])
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model chats {
  id           String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  type         String         @db.VarChar(16)
  name         String?
  owner_id     String         @db.Uuid
  chat_key     String?        @unique(map: "uniq_direct_key")
  created_at   DateTime       @default(now()) @db.Timestamp(6)
  chat_members chat_members[]
  users        users          @relation(fields: [owner_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  messages     messages[]
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model coach_applications {
  id               String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  user_id          String   @db.Uuid
  full_name        String   @db.VarChar(255)
  specialty        String   @db.VarChar(128)
  experience_years Int      @default(0)
  certifications   String
  bio              String?
  website          String?
  instagram        String?
  status           String   @default("PENDING") @db.VarChar(16)
  decision_token   String   @db.VarChar(64)
  review_note      String?
  created_at       DateTime @default(now()) @db.Timestamp(6)
  updated_at       DateTime @default(now()) @db.Timestamp(6)
  users            users    @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "coach_applications_user_fk")

  @@index([status], map: "idx_coach_applications_status")
  @@index([user_id, created_at(sort: Desc)], map: "idx_coach_applications_user")
}

model coach_package_plans {
  package_id     String         @db.Uuid
  plan_id        String         @db.Uuid
  created_at     DateTime       @default(now()) @db.Timestamp(6)
  coach_packages coach_packages @relation(fields: [package_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "coach_package_plans_package_fk")
  plans          plans          @relation(fields: [plan_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "coach_package_plans_plan_fk")

  @@id([package_id, plan_id])
  @@index([plan_id], map: "idx_coach_package_plans_plan")
}

model coach_package_prices {
  package_id     String         @db.Uuid
  currency       String         @db.VarChar(3)
  amount         BigInt
  created_at     DateTime       @default(now()) @db.Timestamp(6)
  updated_at     DateTime       @default(now()) @db.Timestamp(6)
  currencies     currencies     @relation(fields: [currency], references: [code], onDelete: NoAction, onUpdate: NoAction, map: "coach_package_prices_currency_fk")
  coach_packages coach_packages @relation(fields: [package_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "coach_package_prices_package_fk")

  @@id([package_id, currency])
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model coach_packages {
  id                    String                  @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  coach_id              String                  @db.Uuid
  name                  String                  @db.VarChar(128)
  description           String?
  price_monthly         Int?
  price_annual          Int?
  price_one_time        Int?
  trial_days            Int                     @default(0)
  check_in_frequency    String?                 @db.VarChar(32)
  video_access          Boolean                 @default(false)
  nutrition_guides      Boolean                 @default(false)
  custom_features       Json                    @default("[]")
  is_active             Boolean                 @default(true)
  popular               Boolean                 @default(false)
  created_at            DateTime                @default(now()) @db.Timestamp(6)
  updated_at            DateTime                @default(now()) @db.Timestamp(6)
  currency              String                  @default("IRR") @db.VarChar(3)
  billing_type          String                  @default("SUBSCRIPTION") @db.VarChar(16)
  coach_package_plans   coach_package_plans[]
  coach_package_prices  coach_package_prices[]
  users                 users                   @relation(fields: [coach_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "coach_packages_coach_fk")
  orders                orders[]
  package_subscriptions package_subscriptions[]
  plan_assignees        plan_assignees[]

  @@index([coach_id, created_at(sort: Desc)], map: "idx_coach_packages_coach")
}

model coaches {
  user_id     String    @id @db.Uuid
  specialties sports[]
  created_at  DateTime? @default(now()) @db.Timestamp(6)
  updated_at  DateTime? @default(now()) @db.Timestamp(6)
